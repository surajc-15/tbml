generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------
// TBML Application Tables
// ----------------------------------------------------

enum Role {
  ADMIN
  ANALYST
  BANK_USER
}

model User {
  id           String   @id @default(uuid())
  username     String?  @unique
  email        String   @unique
  name         String?
  passwordHash String?
  bankName     String?
  role         Role     @default(BANK_USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model aml_audit_log {
  id               Int      @id @default(autoincrement())
  transactionId    String   @unique @map("transaction_id")
  senderAccount    String?  @map("sender_account")
  receiverAccount  String?  @map("receiver_account")
  amount           Decimal  @db.Decimal(15, 6)
  verdict          String
  confidenceScore  Decimal  @db.Decimal(10, 6) @map("confidence_score")
  strMetadata      Json?    @map("str_metadata")
  actionTaken      String?  @map("action_taken")
  loggedAt         DateTime @default(now()) @map("logged_at")
}